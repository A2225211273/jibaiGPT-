{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "禾序",
  "version": "0.1.0",
  "identifier": "com.muqinghe.hexu",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:4173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "禾序 · Codex 用量助手",
        "url": "index.html?view=desktop&runtime=tauri",
        "width": 380,
        "height": 520,
        "minWidth": 380,
        "minHeight": 520,
        "center": true,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
